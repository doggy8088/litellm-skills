# Copy to .env and replace every placeholder before starting LiteLLM.
# Never commit .env or real provider credentials.
LITELLM_MASTER_KEY=sk-local-change-this-value

MISTRAL_API_KEY=replace-with-mistral_api_key-value
DEEPSEEK_API_KEY=replace-with-deepseek_api_key-value
ANTHROPIC_API_KEY=replace-with-anthropic_api_key-value
GEMINI_API_KEY=replace-with-gemini_api_key-value
CEREBRAS_API_KEY=replace-with-cerebras_api_key-value
TOGETHER_API_KEY=replace-with-together_api_key-value
FIREWORKS_API_KEY=replace-with-fireworks_api_key-value
GROQ_API_KEY=replace-with-groq_api_key-value
OPENAI_API_KEY=replace-with-openai_api_key-value
OPENROUTER_API_KEY=replace-with-openrouter_api_key-value
XAI_API_KEY=replace-with-xai_api_key-value
AZURE_API_KEY=replace-with-azure_api_key-value
OLLAMA_API_KEY=replace-with-ollama_api_key-value
VLLM_API_KEY=replace-with-vllm_api_key-value

# Azure api_base/api_version and local api_base values are kept in YAML.
# Ollama Cloud uses OLLAMA_API_KEY with https://ollama.com; local Ollama is keyless.
# For Docker, replace localhost with host.docker.internal when needed.
